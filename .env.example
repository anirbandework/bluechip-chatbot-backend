# Copy to .env and fill in. NEVER commit the real .env. NEVER expose these to the frontend.
# In production (Railway / Azure), set these as the platform's environment variables.

# ============================ LLM providers ============================
# Configure at least ONE. A provider with no key is shown as unavailable in the UI.
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY or GOOGLE_API_KEY is accepted.
GEMINI_API_KEY=
DEFAULT_PROVIDER=gemini            # which provider when the request doesn't say

# ============================ Database ============================
# Local dev defaults to a SQLite file. In production set this to your Postgres URL
# (Railway provides it; postgresql://… is auto-rewritten to the async driver).
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# ============================ Auth / security ============================
# REQUIRED in production. Generate with:  python -c "import secrets;print(secrets.token_urlsafe(48))"
# (If unset, a random one is used and all sessions reset on every restart.)
JWT_SECRET=
# Optional (defaults shown):
# ACCESS_TOKEN_TTL_MINUTES=30
# REFRESH_TOKEN_TTL_DAYS=14
# INVITE_TOKEN_TTL_HOURS=72
# RESET_TOKEN_TTL_HOURS=2

# ============================ First-run SuperAdmin ============================
# Created automatically on startup ONLY if no user with this email exists.
# This is how the very first admin account comes into being.
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-strong-password
SUPERADMIN_NAME=Super Admin

# ============================ Frontend / links / CORS ============================
# Public URL of the frontend — used to build invite & password-reset links,
# and (as an origin) allowed through CORS.
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ============================ Email (SMTP) — OPTIONAL ============================
# If unset, invite/reset links are surfaced to admins to share manually instead of
# being emailed. Works with any SMTP provider (SendGrid, Resend, Gmail, Azure, …).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=BluChip Agent-Assist <no-reply@yourdomain.com>
# SMTP_STARTTLS=true

# ============================ Optional LLM overrides (defaults shown) ============================
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_MAX_TOKENS=16000
# CLAUDE_EFFORT=high
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-flash-latest
# GEMINI_MAX_TOKENS=8192
# AI_CALL_TIMEOUT_SECONDS=45
