# Copy to .env and fill in. NEVER commit the real .env. NEVER expose these keys to the frontend.
# Configure at least ONE provider. A provider with no key is shown as unavailable
# in the UI and cannot be selected.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google (Gemini) — GEMINI_API_KEY or GOOGLE_API_KEY is accepted ---
GEMINI_API_KEY=

# Which provider to use when the request doesn't specify one.
DEFAULT_PROVIDER=anthropic

# Optional overrides (defaults shown)
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_MAX_TOKENS=16000
# CLAUDE_EFFORT=high
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-flash-latest   # fallback chain (must be available to your key)
# GEMINI_MAX_TOKENS=8192
# AI_CALL_TIMEOUT_SECONDS=45
# CORS_ORIGINS=http://localhost:5173
